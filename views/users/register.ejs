<% layout('layouts/boilerplate') %>

<section class="container py-4 py-lg-5">
    <div class="auth-shell mx-auto">
        <div class="eyebrow text-primary">Create an account</div>
        <h1 class="display-6 mb-2">Start your own city diary</h1>
        <p class="section-copy mb-4">Register once, then keep adding recommendations, hidden gems, and personal travel notes.</p>

        <form action="/register" method="POST" class="validated-form" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="mb-3">
                <label class="form-label" for="username">Username</label>
                <input class="form-control form-control-lg" type="text" id="username" name="username" required autofocus>
            </div>
            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <input class="form-control form-control-lg" type="email" id="email" name="email" required>
            </div>
            <div class="mb-4">
                <label class="form-label" for="password">Password</label>
                <input class="form-control form-control-lg" type="password" id="password" name="password" required>
            </div>
            <button class="btn btn-primary btn-lg w-100 rounded-pill">Register</button>
        </form>
    </div>
</section>
