<% layout('layouts/boilerplate') %>

<section class="container py-4 py-lg-5">
    <div class="auth-shell mx-auto">
        <div class="eyebrow text-primary">Welcome back</div>
        <h1 class="display-6 mb-2">Log in to your diary</h1>
        <p class="section-copy mb-4">Pick up where you left off, add new spots, and manage your saved city notes.</p>

        <% if (dbInfo && dbInfo.isInMemory) { %>
            <div class="preview-callout mb-4">
                Demo account: <code>demo</code> / <code>citydiaries123</code>
            </div>
        <% } %>

        <form action="/login" method="POST" class="validated-form" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="mb-3">
                <label class="form-label" for="username">Username</label>
                <input class="form-control form-control-lg" type="text" id="username" name="username" autofocus required>
            </div>
            <div class="mb-4">
                <label class="form-label" for="password">Password</label>
                <input class="form-control form-control-lg" type="password" id="password" name="password" required>
            </div>
            <button class="btn btn-primary btn-lg w-100 rounded-pill">Login</button>
        </form>
    </div>
</section>
