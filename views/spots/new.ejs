<% layout('layouts/boilerplate') %>

<section class="container py-4 py-lg-5">
    <div class="form-shell mx-auto">
        <div class="eyebrow text-primary">New diary entry</div>
        <h1 class="display-6 mb-2">Add a place worth remembering</h1>
        <p class="section-copy mb-4">Capture what made this spot stand out so your future self or other travelers can find it again.</p>

        <form action="/spots?_csrf=<%= encodeURIComponent(csrfToken) %>" method="POST" novalidate class="validated-form" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="row g-3">
                <div class="col-md-7">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control form-control-lg" type="text" id="title" name="spot[title]" required>
                    <div class="invalid-feedback">Please name the spot.</div>
                </div>
                <div class="col-md-5">
                    <label class="form-label" for="category">Category</label>
                    <select class="form-select form-select-lg" id="category" name="spot[category]" required>
                        <option value="">Choose a category</option>
                        <% categories.forEach(category => { %>
                            <option value="<%= category %>"><%= category %></option>
                        <% }) %>
                    </select>
                    <div class="invalid-feedback">Please choose a category.</div>
                </div>
                <div class="col-12">
                    <label class="form-label" for="location">Location</label>
                    <input class="form-control form-control-lg" type="text" id="location" name="spot[location]" placeholder="City, country or neighborhood" required>
                    <div class="invalid-feedback">Please add a location.</div>
                </div>
                <div class="col-12">
                    <label class="form-label" for="description">Description</label>
                    <textarea class="form-control" id="description" name="spot[description]" rows="6" required></textarea>
                    <div class="invalid-feedback">Please add a short description.</div>
                </div>
                <div class="col-12">
                    <label class="form-label" for="image">Photos</label>
                    <input type="file" class="form-control" id="image" name="image" multiple accept=".jpg,.jpeg,.png,.webp">
                    <div class="form-text">Add a few images if you have them. Local uploads work in preview mode too.</div>
                </div>
            </div>
            <div class="d-flex flex-wrap gap-3 mt-4">
                <button class="btn btn-primary btn-lg rounded-pill px-4">Publish entry</button>
                <a href="/spots" class="btn btn-outline-dark btn-lg rounded-pill px-4">Back to explore</a>
            </div>
        </form>
    </div>
</section>
