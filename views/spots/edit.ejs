<% layout('layouts/boilerplate') %>

<section class="container py-4 py-lg-5">
    <div class="form-shell mx-auto">
        <div class="eyebrow text-primary">Update entry</div>
        <h1 class="display-6 mb-2">Edit your diary note</h1>
        <p class="section-copy mb-4">Refresh the details, add more photos, or clean up anything you want to improve.</p>

        <form action="/spots/<%= spot._id %>?_method=PUT" method="POST" novalidate class="validated-form" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="row g-3">
                <div class="col-md-7">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control form-control-lg" type="text" id="title" name="spot[title]" value="<%= spot.title %>" required>
                </div>
                <div class="col-md-5">
                    <label class="form-label" for="category">Category</label>
                    <select class="form-select form-select-lg" id="category" name="spot[category]" required>
                        <option value="">Choose a category</option>
                        <% categories.forEach(category => { %>
                            <option value="<%= category %>" <%= spot.category === category ? 'selected' : '' %>><%= category %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label" for="location">Location</label>
                    <input class="form-control form-control-lg" type="text" id="location" name="spot[location]" value="<%= spot.location %>" required>
                </div>
                <div class="col-12">
                    <label class="form-label" for="description">Description</label>
                    <textarea class="form-control" id="description" name="spot[description]" rows="6" required><%= spot.description %></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label" for="image">Add more photos</label>
                    <input type="file" class="form-control" id="image" name="image" multiple accept=".jpg,.jpeg,.png,.webp">
                </div>
            </div>

            <% if (spot.images.length) { %>
                <div class="mt-4">
                    <h2 class="h5 mb-3">Current photos</h2>
                    <div class="image-grid">
                        <% spot.images.forEach((img, i) => { %>
                            <label class="image-check-card">
                                <img src="<%= img.thumbnail || img.url %>" alt="Spot image <%= i + 1 %>">
                                <span class="form-check">
                                    <input class="form-check-input" type="checkbox" name="deleteImages[]" value="<%= img.filename %>">
                                    <span>Remove</span>
                                </span>
                            </label>
                        <% }) %>
                    </div>
                </div>
            <% } %>

            <div class="d-flex flex-wrap gap-3 mt-4">
                <button class="btn btn-primary btn-lg rounded-pill px-4">Save changes</button>
                <a href="/spots/<%= spot._id %>" class="btn btn-outline-dark btn-lg rounded-pill px-4">Back to entry</a>
            </div>
        </form>
    </div>
</section>
