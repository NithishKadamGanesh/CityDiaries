<% layout('layouts/boilerplate') %>

<section class="container py-4 py-lg-5">
    <div class="section-heading mb-4">
        <div>
            <div class="eyebrow text-dark-emphasis"><%= isDiary ? 'Private collection' : 'Shared feed' %></div>
            <h1 class="display-6 mb-2"><%= pageTitle %></h1>
            <p class="section-copy mb-0"><%= intro %></p>
        </div>
        <a href="<%= actionHref %>" class="btn btn-dark rounded-pill px-4"><%= actionLabel %></a>
    </div>

    <form class="search-panel mb-4" action="<%= pageTitle === 'Saved Spots' ? '/spots/saved' : (isDiary ? '/spots/myspots' : '/spots') %>" method="GET">
        <div class="row g-3 align-items-end">
            <div class="col-lg-5">
                <label class="form-label" for="q">Search</label>
                <input class="form-control form-control-lg" type="text" id="q" name="q" value="<%= filters.q %>" placeholder="Search by title, city, or description">
            </div>
            <div class="col-md-4 col-lg-3">
                <label class="form-label" for="category">Category</label>
                <select class="form-select form-select-lg" id="category" name="category">
                    <option value="">All categories</option>
                    <% categories.forEach(category => { %>
                        <option value="<%= category %>" <%= filters.category === category ? 'selected' : '' %>><%= category %></option>
                    <% }) %>
                </select>
            </div>
            <% if (pageTitle === 'Saved Spots') { %>
                <div class="col-md-4 col-lg-2">
                    <label class="form-label" for="status">Status</label>
                    <select class="form-select form-select-lg" id="status" name="status">
                        <option value="">All statuses</option>
                        <% savedStatusOptions.forEach(option => { %>
                            <option value="<%= option.value %>" <%= filters.status === option.value ? 'selected' : '' %>><%= option.label %></option>
                        <% }) %>
                    </select>
                </div>
            <% } %>
            <div class="col-md-4 col-lg-2">
                <label class="form-label" for="sort">Sort</label>
                <select class="form-select form-select-lg" id="sort" name="sort">
                    <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest</option>
                    <option value="rating" <%= filters.sort === 'rating' ? 'selected' : '' %>>Top rated</option>
                    <option value="reviews" <%= filters.sort === 'reviews' ? 'selected' : '' %>>Most reviewed</option>
                    <option value="title" <%= filters.sort === 'title' ? 'selected' : '' %>>Title</option>
                    <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-2 d-grid">
                <button class="btn btn-primary btn-lg">Apply</button>
            </div>
        </div>
    </form>

    <% if (!spots.length) { %>
        <div class="empty-state">
            <div class="eyebrow text-primary">Nothing here yet</div>
            <h2 class="h3 mt-2">No matching spots found</h2>
            <p class="mb-4"><%= emptyState %></p>
            <a href="<%= actionHref %>" class="btn btn-dark rounded-pill px-4"><%= actionLabel %></a>
        </div>
    <% } else { %>
        <div class="row g-4">
            <% spots.forEach(spot => { %>
                <div class="col-md-6 col-xl-4">
                    <article class="spot-card h-100">
                        <img class="spot-card-image" src="<%= spot.coverImage %>" alt="<%= spot.title %>">
                        <div class="spot-card-body">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <span class="badge text-bg-light rounded-pill mb-2"><%= spot.category %></span>
                                    <h2 class="h4 mb-1"><%= spot.title %></h2>
                                    <p class="text-secondary mb-0"><%= spot.location %></p>
                                </div>
                                <div class="rating-pill">
                                    <strong><%= spot.ratingAverage.toFixed(1) %></strong>
                                    <span>/ 5</span>
                                </div>
                            </div>
                            <p class="spot-card-copy"><%= spot.description.length > 145 ? `${spot.description.slice(0, 145)}...` : spot.description %></p>
                            <div class="spot-card-meta">
                                <span>By <%= spot.author.username %></span>
                                <span><%= spot.ratingCount %> review<%= spot.ratingCount === 1 ? '' : 's' %></span>
                                <span><%= spot.createdAt.toLocaleDateString() %></span>
                            </div>
                            <% if (savedSpotStatuses[String(spot._id)]) { %>
                                <div class="mt-3">
                                    <span class="badge text-bg-warning rounded-pill px-3 py-2">
                                        <%= savedStatusOptions.find(option => option.value === savedSpotStatuses[String(spot._id)]).label %>
                                    </span>
                                </div>
                            <% } %>
                            <a class="btn btn-outline-dark rounded-pill mt-4" href="/spots/<%= spot._id %>">Read entry</a>
                        </div>
                    </article>
                </div>
            <% }) %>
        </div>

        <% if (pagination.totalPages > 1) { %>
            <nav class="mt-5" aria-label="Diary pagination">
                <ul class="pagination justify-content-center gap-2 flex-wrap">
                    <li class="page-item <%= pagination.hasPrev ? '' : 'disabled' %>">
                        <a class="page-link rounded-pill" href="<%= buildPageLink(pagination.prevPage) %>">Previous</a>
                    </li>
                    <% for (let page = 1; page <= pagination.totalPages; page++) { %>
                        <li class="page-item <%= page === pagination.currentPage ? 'active' : '' %>">
                            <a class="page-link rounded-pill" href="<%= buildPageLink(page) %>"><%= page %></a>
                        </li>
                    <% } %>
                    <li class="page-item <%= pagination.hasNext ? '' : 'disabled' %>">
                        <a class="page-link rounded-pill" href="<%= buildPageLink(pagination.nextPage) %>">Next</a>
                    </li>
                </ul>
            </nav>
        <% } %>
    <% } %>
</section>
