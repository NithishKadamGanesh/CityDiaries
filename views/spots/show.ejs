<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/stars.css">

<section class="container py-4 py-lg-5">
    <div class="row g-4 g-lg-5">
        <div class="col-lg-7">
            <img src="<%= spot.coverImage %>" class="detail-hero-image" alt="<%= spot.title %>">

            <div class="detail-card mt-4">
                <div class="d-flex flex-wrap justify-content-between gap-3">
                    <div>
                        <span class="badge text-bg-light rounded-pill mb-2"><%= spot.category %></span>
                        <h1 class="display-6 mb-2"><%= spot.title %></h1>
                        <p class="text-secondary mb-0"><%= spot.location %></p>
                    </div>
                    <div class="rating-panel">
                        <div class="rating-score"><%= spot.ratingAverage.toFixed(1) %></div>
                        <div class="text-secondary"><%= spot.ratingCount %> review<%= spot.ratingCount === 1 ? '' : 's' %></div>
                    </div>
                </div>

                <p class="detail-copy mt-4"><%= spot.description %></p>

                <div class="detail-meta">
                    <span>Shared by <strong><%= spot.author.username %></strong></span>
                    <span>Published <%= spot.createdAt.toLocaleDateString() %></span>
                    <span>Category: <%= spot.category %></span>
                </div>

                <% if (currentUser) { %>
                    <form action="/spots/<%= spot._id %>/favorite" method="POST" class="mt-4">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn <%= isFavorited ? 'btn-warning' : 'btn-outline-dark' %> rounded-pill px-4">
                            <%= isFavorited ? 'Saved to favorites' : 'Save this spot' %>
                        </button>
                    </form>
                <% } %>

                <% if (currentUser && spot.author.equals(currentUser._id)) { %>
                    <div class="d-flex flex-wrap gap-3 mt-4">
                        <a class="btn btn-dark rounded-pill px-4" href="/spots/<%= spot._id %>/edit">Edit entry</a>
                        <form action="/spots/<%= spot._id %>?_method=DELETE" method="POST">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button class="btn btn-outline-danger rounded-pill px-4">Delete entry</button>
                        </form>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="detail-card mb-4">
                <h2 class="h4 mb-3">Map preview</h2>
                <iframe class="map-frame" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
                    src="https://www.google.com/maps?q=<%= encodeURIComponent(`${spot.title} ${spot.location}`) %>&output=embed"
                    allowfullscreen></iframe>
            </div>

            <% if (currentUser) { %>
                <div class="detail-card mb-4">
                    <h2 class="h4 mb-3">Leave a review</h2>
                    <form action="/spots/<%= spot._id %>/reviews" method="POST" class="validated-form" novalidate>
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <fieldset class="starability-basic mb-3">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating.">
                            <input type="radio" id="first-rate1" name="review[rating]" value="1">
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2">
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3">
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4">
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5">
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                        <div class="mb-3">
                            <label class="form-label" for="body">Review</label>
                            <textarea class="form-control" name="review[body]" id="body" rows="4" required></textarea>
                            <div class="invalid-feedback">Please write a few words about the place.</div>
                        </div>
                        <button class="btn btn-primary rounded-pill px-4">Submit review</button>
                    </form>
                </div>
            <% } %>

            <div class="detail-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h4 mb-0">Recent reviews</h2>
                    <span class="text-secondary"><%= spot.ratingCount %> total</span>
                </div>

                <% if (!spot.reviews.length) { %>
                    <p class="text-secondary mb-0">No reviews yet. Be the first person to share what stood out.</p>
                <% } %>

                <% spot.reviews.forEach(review => { %>
                    <article class="review-card">
                        <div class="d-flex justify-content-between gap-3">
                            <div>
                                <h3 class="h6 mb-1"><%= review.author.username %></h3>
                                <p class="starability-result mb-2" data-rating="<%= review.rating %>">
                                    Rated: <%= review.rating %> stars
                                </p>
                            </div>
                            <span class="text-secondary small"><%= review.createdAt.toLocaleDateString() %></span>
                        </div>
                        <p class="mb-0"><%= review.body %></p>

                        <% if (currentUser && review.author.equals(currentUser._id)) { %>
                            <form action="/spots/<%= spot._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="mt-3">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button class="btn btn-sm btn-outline-danger rounded-pill">Delete review</button>
                            </form>
                        <% } %>
                    </article>
                <% }) %>
            </div>
        </div>
    </div>
</section>
