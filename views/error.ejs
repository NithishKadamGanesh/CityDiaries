<% layout('layouts/boilerplate') %>

<section class="container py-5">
    <div class="empty-state">
        <div class="eyebrow text-danger">Something went wrong</div>
        <h1 class="display-6 mt-2"><%= err.statusCode || 500 %></h1>
        <p class="mb-4"><%= err.message %></p>
        <a href="/" class="btn btn-dark rounded-pill px-4">Go home</a>
    </div>
</section>
